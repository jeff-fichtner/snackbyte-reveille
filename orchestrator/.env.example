# Orchestrator configuration — copy to `orchestrator/.env` and fill in.
#
# NOTHING HERE IS OPTIONAL AND NOTHING HAS A DEFAULT. A missing or blank value
# makes the orchestrator refuse to start, naming the variable.
#
# `orchestrator/.env` is gitignored and MUST NOT be committed. The repository is
# public and DISCORD_BOT_TOKEN is a credential — leaking it hands over the bot.

# From the Discord developer portal, Bot -> Token. Secret.
DISCORD_BOT_TOKEN=

# Application (client) ID of the Discord app. Not secret, but required.
DISCORD_APPLICATION_ID=

# The one Discord server the commands are registered to. Guild-scoped commands
# appear immediately; global ones take up to an hour to propagate.
DISCORD_GUILD_ID=

# Where this orchestrator's agent answers. An agent's URL IS its identity — there
# is no server id or discriminator anywhere in the contract (Constitution I), so a
# second controlled server is a second address, never a parameter.
#
# Loopback today because the orchestrator and agent share `watson`. The moment
# this points off-box, the agent is exposed to the network and the no-auth trade
# expires — authentication becomes a prerequisite, not an enhancement (FR-013).
AGENT_BASE_URL=http://127.0.0.1:8300
