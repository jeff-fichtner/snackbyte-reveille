{
  "name": "snackbyte-reveille",
  "private": true,
  "version": "0.2.0",
  "description": "An on-demand control plane for self-hosted game servers.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "contract",
    "agent",
    "orchestrator"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "node --test \"**/*.test.ts\"",
    "check:all": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0"
  }
}
