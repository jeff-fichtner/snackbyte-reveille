# Agent configuration — copy to `agent/.env` and fill in with real values.
#
# NOTHING HERE IS OPTIONAL AND NOTHING HAS A DEFAULT. A missing or blank value
# makes the agent refuse to start, naming the variable. That is deliberate: a
# silent fallback turns "you forgot to set this" into mysterious wrong behaviour
# later, and one of these is an admin credential.
#
# `agent/.env` is gitignored and MUST NOT be committed. The repository is public.

# Port the agent listens on. Bound to 127.0.0.1 ONLY — the bind address is not
# configurable, so no edit here can accidentally expose it (FR-013).
AGENT_PORT=8300

# Full path to the Palworld launcher. Windows path; quote it if it has spaces.
# Note this is the LAUNCHER — it spawns PalServer-Win64-Shipping-Cmd.exe and may
# exit while the real server keeps running (research R2).
PALWORLD_EXE_PATH=C:\steamcmd\steamapps\common\PalServer\PalServer.exe

# Base URL of the Palworld REST API. Loopback — this must never be reachable
# off-box (FR-014, FR-015).
PALWORLD_REST_BASE_URL=http://127.0.0.1:8212

# Password for `AdminPassword` in PalWorldSettings.ini. REST Basic auth depends on
# it. A blank admin password is an open admin interface, so the agent refuses to
# start without one.
PALWORLD_ADMIN_PASSWORD=

# Hard ceiling in milliseconds on a whole /stop — save, verify, then shutdown.
# Exceeding it fails the stop and LEAVES THE SERVER RUNNING; a stop that hangs is
# as bad as one that loses data (FR-007). Must be a positive integer.
STOP_TIMEOUT_MS=30000
